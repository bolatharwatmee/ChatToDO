# ===== ChatToDO configuration =====
# Copy this file to ".env" and fill in the values you need.

# ---- Messaging platform ----
# If TELEGRAM_BOT_TOKEN is set, the bot runs on Telegram (recommended: reliable
# notifications, no phone number). Otherwise it runs on WhatsApp.
# Create a bot with @BotFather in Telegram to get a token.
TELEGRAM_BOT_TOKEN=
# Optional: restrict the bot to only you. Get your numeric id from @userinfobot.
TELEGRAM_OWNER_ID=

# ---- WhatsApp (only used if TELEGRAM_BOT_TOKEN is empty) ----

# Your WhatsApp number in international format, digits only (no +, no spaces).
# The bot will ONLY listen/respond to this number. Leave empty to allow anyone
# who messages the linked account (not recommended).
OWNER_NUMBER=201273533815

# Timezone used when parsing things like "tomorrow 5pm" and for reminders.
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Africa/Cairo

# Default time of day (24h, HH:MM) used for date-only reminders like
# "remind me to call mom tomorrow" (no explicit time).
DEFAULT_REMINDER_TIME=09:00

# Link without scanning a QR code: set this to your number (digits only) and the
# bot prints an 8-char pairing code to enter in WhatsApp →
# Linked devices → "Link with phone number instead". Leave empty to use QR.
PAIRING_NUMBER=

# ---- Voice transcription (optional) ----
# Provider for turning WhatsApp voice notes into text.
#   auto   -> use groq if GROQ_API_KEY set, else openai if OPENAI_API_KEY set,
#             else local whisper, else disabled.
#   groq   -> Groq Whisper API (free tier, fast). Needs GROQ_API_KEY.
#   openai -> OpenAI Whisper API. Needs OPENAI_API_KEY.
#   local  -> local whisper.cpp via the optional "nodejs-whisper" package + ffmpeg.
#   off    -> ignore voice notes and ask the user to send text.
TRANSCRIPTION_PROVIDER=auto

# Get a free key at https://console.groq.com  (recommended for voice)
GROQ_API_KEY=

# Optional, if you prefer OpenAI for transcription.
OPENAI_API_KEY=
